{
  "dashboard": {
    "title": "VuProject Certificate Management Dashboard",
    "tags": ["certificates", "monitoring"],
    "timezone": "browser",
    "panels": [
      {
        "id": 1,
        "title": "Certificate Status Overview",
        "type": "stat",
        "gridPos": {"h": 8, "w": 6, "x": 0, "y": 0},
        "targets": [
          {
            "expr": "certificates_total",
            "legendFormat": "Total Certificates"
          }
        ]
      },
      {
        "id": 2,
        "title": "Valid Certificates",
        "type": "stat",
        "gridPos": {"h": 8, "w": 6, "x": 6, "y": 0},
        "targets": [
          {
            "expr": "certificates_valid",
            "legendFormat": "Valid"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "thresholds"},
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "green", "value": null}
              ]
            }
          }
        }
      },
      {
        "id": 3,
        "title": "Expiring Soon",
        "type": "stat",
        "gridPos": {"h": 8, "w": 6, "x": 12, "y": 0},
        "targets": [
          {
            "expr": "certificates_expiring_soon",
            "legendFormat": "Expiring Soon"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "thresholds"},
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "orange", "value": null}
              ]
            }
          }
        }
      },
      {
        "id": 4,
        "title": "Expired Certificates",
        "type": "stat",
        "gridPos": {"h": 8, "w": 6, "x": 18, "y": 0},
        "targets": [
          {
            "expr": "certificates_expired",
            "legendFormat": "Expired"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "thresholds"},
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "red", "value": null}
              ]
            }
          }
        }
      },
      {
        "id": 5,
        "title": "Certificate Issuance Over Time",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
        "targets": [
          {
            "expr": "rate(certificates_issued_total[5m])",
            "legendFormat": "Issuance Rate"
          }
        ]
      },
      {
        "id": 6,
        "title": "Certificate Revocation Over Time",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
        "targets": [
          {
            "expr": "rate(certificates_revoked_total[5m])",
            "legendFormat": "Revocation Rate"
          }
        ]
      },
      {
        "id": 7,
        "title": "API Response Time",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
        "targets": [
          {
            "expr": "rate(http_request_duration_seconds_sum[5m]) / rate(http_request_duration_seconds_count[5m])",
            "legendFormat": "Avg Response Time"
          }
        ]
      },
      {
        "id": 8,
        "title": "System Health",
        "type": "table",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
        "targets": [
          {
            "expr": "up",
            "legendFormat": "{{job}}"
          }
        ]
      }
    ],
    "schemaVersion": 16,
    "version": 0
  }
}

